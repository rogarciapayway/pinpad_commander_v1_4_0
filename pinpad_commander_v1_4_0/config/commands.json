{
  "stx": 2,
  "etx": 3,
  "fs": 28,
  "commands": {
    "Y0I Información": {
      "cid": "Y0I",
      "description": "🔍 Identificación del PinPad - Obtiene información del dispositivo",
      "request": {
        "fields": []
      },
      "io": {
        "expect_ack": true
      },
      "response": {
        "validate_cid": true,
        "parser": {
          "type": "fs",
          "fields": [
            {
              "name": "owner",
              "description": "Propietario del PinPad",
              "decode": "trim"
            },
            {
              "name": "vendor",
              "description": "Fabricante",
              "decode": "trim"
            },
            {
              "name": "model",
              "description": "Modelo del PP",
              "decode": "trim"
            },
            {
              "name": "os_version",
              "description": "Version de OS",
              "decode": "trim"
            },
            {
              "name": "soft_version",
              "description": "Version de Soft",
              "decode": "trim"
            },
            {
              "name": "serial",
              "description": "Nro de Serie",
              "decode": "trim"
            }
          ]
        }
      }
    },
    "Y19 Transacción": {
      "cid": "Y19",
      "description": "💳 Transacción (Y19) — RSA/EXP",
      "request": {
        "fields": [
          {
            "name": "RSA",
            "description": "🔑 Clave pública RSA en hexadecimal (512 bytes = 1024 chars hex)",
            "default": "",
            "format": {
              "type": "upper"
            }
          },
          {
            "name": "EXP",
            "description": "🔢 Exponente RSA (típicamente 65537 = 10001 hex)",
            "default": "10001",
            "format": {
              "type": "digits"
            }
          },
          {
            "name": "TEC",
            "description": "⌨️ Tiempo entre comandos (060=Default)",
            "default": "060",
            "format": {
              "type": "padleft",
              "len": 3,
              "ch": "0"
            }
          },
          {
            "name": "ET1",
            "description": "💳 Envia track I: 0=No, 1=Si",
            "default": "1",
            "format": {
              "type": "padleft",
              "len": 1,
              "ch": "0"
            }
          },
          {
            "name": "PTC",
            "description": "🔐 Pide Tipo de cuenta: 0=No, 1=Si",
            "default": "0",
            "format": {
              "type": "padleft",
              "len": 1,
              "ch": "0"
            }
          },
          {
            "name": "PMK",
            "description": "🔑 Posición Master Key: 2=Lane / N6 Prod, G=N910 Prod, 1=N910 / N6 Test, N=No",
            "default": "1",
            "format": {
              "type": "padleft",
              "len": 1,
              "ch": "0"
            }
          },
          {
            "name": "WRK",
            "description": "🔧 Working Key: N=No",
            "default": "N",
            "format": {
              "type": "padleft",
              "len": 1,
              "ch": "N"
            }
          },
          {
            "name": "ENC",
            "description": "🔒 Encriptación: 0=No, 1=Sí",
            "default": "0",
            "format": {
              "type": "padleft",
              "len": 1,
              "ch": "0"
            }
          },
          {
            "name": "IMP",
            "description": "💰 Importe de la transacción (ej: 123.45)",
            "default": "123.45",
            "format": {
              "type": "amount",
              "decimals": 2,
              "pad": 12
            }
          },
          {
            "name": "ICB",
            "description": "💵 Importe de cashback / Propina(ej: 0.00)",
            "default": "0.00",
            "format": {
              "type": "amount",
              "decimals": 2,
              "pad": 12
            }
          },
          {
            "name": "TTY",
            "description": "📱 Tipo de transacción: 00=Compra, 09=Compra + Cash, etc.",
            "default": "00",
            "format": {
              "type": "padleft",
              "len": 2,
              "ch": "0"
            }
          }
        ],
        "segments": [
          {"type": "field", "name": "RSA"},
          {"type": "fs"},
          {"type": "field", "name": "EXP"},
          {"type": "fs"},
          {"type": "field", "name": "TEC"},
          {"type": "field", "name": "ET1"},
          {"type": "field", "name": "PTC"},
          {"type": "field", "name": "PMK"},
          {"type": "field", "name": "WRK"},
          {"type": "fs"},
          {"type": "field", "name": "ENC"},
          {"type": "field", "name": "IMP"},
          {"type": "field", "name": "ICB"},
          {"type": "field", "name": "TTY"}
        ]
      },
      "io": {
        "expect_ack": true,
        "timeout_sec": 60
      },
      "response": {
        "validate_cid": true,
        "parser": {
          "type": "fs",
          "fields": [
            {
              "name": "tarj_enmasc",
              "description": "💳 Número de Tarjeta (8 primeros + 4 últimos, resto enmascarado)",
              "decode": "trim"
            },
            {
              "name": "CSE_CBC_NYA",
              "description": "🔢 Código Servicio + CBC + Nombre/Apellido",
              "decode": "trim",
              "post": "parse_cse_cbc_nya",
              "flatten": true
            },
            {
              "name": "REG_MDI_VER",
              "description": "⚠️ REG + Modo Ingreso + Versión",
              "decode": "trim",
              "post": "parse_reg_mdi_ver",
              "flatten": true
            },
            {
              "name": "FDV_TC2",
              "description": "📅 Fecha Expiración + Track II encriptado",
              "decode": "trim",
              "post": "parse_fdv_tc2",
              "flatten": true
            },
            {
              "name": "1NL_NSF",
              "description": "📖 Track1 no leído + Número Serie Físico",
              "decode": "trim",
              "post": "parse_1nl_nsf",
              "flatten": true
            },
            {
              "name": "CPG",
              "description": "💳 Criptograma de las Tarjetas EMV",
              "decode": "tlv_hex",
              "post": "emv_pretty"
            },
            {
              "name": "CAU_CRE_NSP_APN",
              "description": "🔢 CAU + CRE + NSP + APN combinados",
              "decode": "trim",
              "post": "parse_cau_cre_nsp_apn",
              "flatten": true
            },
            {
              "name": "aid",
              "description": "🆔 Identificador de la Aplicación seleccionada en el CHIP",
              "decode": "trim"
            },
            {
              "name": "TDC_PIN",
              "description": "📋 Tipo de cuenta + PIN",
              "decode": "trim",
              "post": "parse_tdc_pin",
              "flatten": true
            },
            {
              "name": "ksn",
              "description": "🔑 TKSN correspondiente a PINBLOCK",
              "decode": "trim"
            }
          ]
        }
      }
    },
