{
  "validaciones_condicionales": {
    "campo_52_presente": {
      "descripcion": "Si el campo 52 (PIN Block) está presente, deben estar estos productos en campo 59",
      "condicion": "campo_52_presente",
      "productos_requeridos": ["028", "084"],
      "validacion": "if (campo52.presente) { validarProductos(campo59, ['028', '084']); }"
    },
    "modo_chip_contactless": {
      "descripcion": "Si campo 22 indica chip (051) o contactless (071), validar TAGs EMV en campo 55",
      "condicion": "campo_22 === '051' || campo_22 === '071'",
      "campo_validar": "55",
      "validacion": "if (campo22 === '051' || campo22 === '071') { validarEMVTags(campo55, emvTags); }"
    },
    "operaciones_qr_cierre": {
      "descripcion": "Si hay operaciones con QR, debe estar producto 083 en campo 59 del mensaje 0500",
      "condicion": "mensaje === '0500' && operaciones_qr",
      "productos_requeridos": ["083"],
      "validacion": "if (mensaje === '0500' && tieneOperacionesQR) { validarProducto(campo59, '083'); }"
    },
    "mpos_mastercard": {
      "descripcion": "Para mPOS con MasterCard/Maestro, producto 078 debe incluir subcampo 211",
      "condicion": "producto_078_presente && (mastercard || maestro)",
      "subcampo_requerido": "211",
      "validacion": "if (producto078.presente && (esMasterCard || esMaestro)) { validarSubcampo(producto078, '211'); }"
    },
    "capacidad_captura": {
      "descripcion": "Producto 021 debe coincidir con capacidades declaradas del terminal",
      "condicion": "siempre",
      "campo_relacionado": "22",
      "validacion": "validarCoherenciaCapacidad(producto021, campo22, capacidadesTerminal);"
    },
    "fallback_chip": {
      "descripcion": "Producto 022 (Fallback) solo debe aparecer en transacciones que intentaron chip",
      "condicion": "producto_022_presente",
      "validacion_logica": "chip_intento_fallido",
      "validacion": "if (producto022.presente) { validarIntentoChip(transaccion); }"
    }
  },
  "validaciones_estructura": {
    "campo_59_mandatorio": {
      "descripcion": "Campo 59 siempre debe contener al menos el producto 021",
      "productos_minimos": ["021"],
      "validacion": "validarProductoMandatorio(campo59, '021');"
    },
    "formato_productos": {
      "descripcion": "Validar estructura BCD/ASCII de cada producto",
      "validacion": "validarEstructuraProductos(campo59, estructurasProductos);"
    },
    "longitudes_coherentes": {
      "descripcion": "Longitud total debe coincidir con suma de subcampos",
      "validacion": "validarLongitudesProductos(campo59);"
    }
  },
  "validaciones_por_mensaje": {
    "0200": {
      "descripcion": "Mensajes de autorización (compra, anulación, devolución)",
      "productos_mandatorios": ["021"],
      "productos_condicionales": {
        "pin_presente": ["028", "084"],
        "mpos": ["078"],
        "fallback": ["022"]
      }
    },
    "0220": {
      "descripcion": "Mensajes de advice",
      "productos_mandatorios": ["021"],
      "productos_condicionales": {
        "pin_presente": ["028", "084"],
        "mpos": ["078"]
      }
    },
    "0500": {
      "descripcion": "Cierre de lote",
      "productos_mandatorios": ["021"],
      "productos_condicionales": {
        "operaciones_qr": ["083"]
      }
    }
  },
  "reglas_negocio": {
    "coherencia_capacidades": {
      "descripcion": "Producto 021 debe ser coherente con campo 22 y capacidades del terminal",
      "validacion": "validarCoherenciaCapacidades(producto021, campo22, terminalCapacidades);"
    },
    "encripcion_pin": {
      "descripcion": "Si hay PIN (campo 52), debe haber productos de encripción",
      "validacion": "if (campo52.presente) { validarEncripcion(campo59); }"
    },
    "mpos_identificacion": {
      "descripcion": "Dispositivos mPOS deben identificarse correctamente",
      "validacion": "if (esMPOS) { validarIdentificacionMPOS(campo59); }"
    }
  }
}